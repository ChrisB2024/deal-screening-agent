# --- Environment ---
APP_ENV=dev
# SECRETS_PROVIDER=env_file  (auto-detected from APP_ENV)
# KMS_PROVIDER=none

# --- Database (non-secret config) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deal_screening
DB_DRIVER=postgresql+asyncpg

# --- Secrets (loaded by SecretsClient via the provider) ---
OPENAI_API_KEY=sk-...
DATABASE_PASSWORD=your-db-password
AUTH_SIGNING_KEY_CURRENT=generate-a-real-key
# AUTH_SIGNING_KEY_PREVIOUS=
# RATE_LIMIT_STORE_PASSWORD=
# AUTH_MIN_IAT_WATERMARK=0

# --- Storage ---
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# --- LLM ---
LLM_MODEL=gpt-4o

# --- Legacy (still read by old config.py during migration) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deal_screening
JWT_SECRET_KEY=generate-a-real-secret-here
